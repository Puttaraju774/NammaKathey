<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/royal_blue"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Lamp glow icon -->
    <TextView
        android:id="@+id/lampIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🪔"
        android:textSize="64sp"
        android:layout_marginBottom="16dp"/>

    <!-- Logo placeholder (replace with actual logo drawable) -->
    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/logo"
        android:layout_marginBottom="24dp"/>

    <!-- App Title -->
    <TextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Namma-Kathey"
        android:textColor="@color/saffron"
        android:textSize="36sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"/>

    <!-- Kannada subtitle -->
    <TextView
        android:id="@+id/appSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ನಮ್ಮ ಕಥೆ"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:layout_marginTop="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Karnataka's Brave Heroes"
        android:textColor="#AAAACC"
        android:textSize="14sp"
        android:layout_marginTop="8dp"/>

    <!-- Loading dots -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="48dp">
        <View android:layout_width="8dp" android:layout_height="8dp"
            android:background="@drawable/dot_selected" android:layout_marginEnd="6dp"/>
        <View android:layout_width="8dp" android:layout_height="8dp"
            android:background="@drawable/dot_unselected" android:layout_marginEnd="6dp"/>
        <View android:layout_width="8dp" android:layout_height="8dp"
            android:background="@drawable/dot_unselected"/>
    </LinearLayout>

</LinearLayout>