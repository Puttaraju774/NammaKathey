<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8F4FD">

    <!-- TOP BAR -->
    <LinearLayout android:id="@+id/topBar"
        android:layout_width="0dp" android:layout_height="60dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:background="#E8F4FD"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="40dp" android:layout_height="40dp"
                android:src="@drawable/logo"
                android:scaleType="fitCenter"
                android:layout_marginEnd="10dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Namma Kathey"
                android:textColor="#1A73C8" android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="36dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@drawable/pill_outline_gold"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:layout_marginEnd="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🏅" android:textSize="14sp"/>
            <TextView android:id="@+id/tvBadgeCount"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text=" 0" android:textColor="#8B6914"
                android:textSize="14sp" android:textStyle="bold"/>
        </LinearLayout>

        <Button android:id="@+id/btnLanguage"
            android:layout_width="wrap_content" android:layout_height="34dp"
            android:text="ಕನ್ನಡ" android:textSize="11sp"
            android:textColor="#1B3A6B" android:backgroundTint="#E8A020"
            app:cornerRadius="10dp"/>

    </LinearLayout>

    <!-- DIVIDER -->
    <View android:id="@+id/divider"
        android:layout_width="0dp" android:layout_height="1dp"
        android:background="#C8E6F5"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SWIPE PILL -->
    <TextView android:id="@+id/tvSwipePill"
        android:layout_width="wrap_content" android:layout_height="34dp"
        android:text="✦ SWIPE TO DISCOVER ✦"
        android:textColor="#555577" android:textSize="12sp"
        android:textStyle="bold" android:letterSpacing="0.1"
        android:gravity="center"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:background="@drawable/pill_swipe_bg"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SUBTITLE -->
    <TextView android:id="@+id/tvAppTitleKn"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Meet Karnataka's Heroes!"
        android:textColor="#1A1A2E" android:textSize="18sp"
        android:textStyle="bold" android:gravity="center"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvSwipePill"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- HERO CAROUSEL -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/heroCarousel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppTitleKn"
        app:layout_constraintBottom_toTopOf="@id/carouselDots"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- CAROUSEL DOTS -->
    <LinearLayout
        android:id="@+id/carouselDots"
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/btnExplore"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- EXPLORE BUTTON -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btnExplore"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFF8E7"
        app:layout_constraintBottom_toTopOf="@id/tvQuickQuests"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp" android:paddingEnd="16dp">

            <TextView android:layout_width="36dp" android:layout_height="36dp"
                android:background="@drawable/circle_saffron"
                android:gravity="center" android:text="📖"
                android:textSize="16sp" android:layout_marginEnd="12dp"/>

            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Explore All Heroes"
                android:textColor="#1A1A2E" android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textColor="#E8A020"
                android:textSize="28sp" android:textStyle="bold"/>

            <TextView android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/circle_gold"
                android:gravity="center" android:text="🦁"
                android:textSize="18sp" android:layout_marginStart="8dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- QUICK QUESTS -->
    <LinearLayout android:id="@+id/tvQuickQuests"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Quick Quests"
            android:textColor="#1A1A2E" android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView android:id="@+id/tvSeeAll"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="See All"
            android:textColor="#1A73C8" android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- BOTTOM NAV -->
    <!-- BOTTOM NAV -->
    <LinearLayout android:id="@+id/bottomNav"
        android:layout_width="0dp" android:layout_height="64dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Home -->
        <LinearLayout android:id="@+id/navHome"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏠" android:textSize="22sp"/>
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home" android:textColor="#1A73C8"
                android:textSize="11sp" android:textStyle="bold"/>
        </LinearLayout>

        <!-- Explore -->
        <LinearLayout android:id="@+id/navMap"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🗺️" android:textSize="22sp"/>
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explore" android:textColor="#999999"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- Badges (renamed from Rewards) -->
        <LinearLayout android:id="@+id/navRewards"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏅" android:textSize="22sp"/>
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Badges" android:textColor="#999999"
                android:textSize="11sp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>