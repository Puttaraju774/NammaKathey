<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="8dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="16dp"
    app:cardBackgroundColor="#1B3A6B">

    <LinearLayout android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical" android:gravity="center"
        android:padding="20dp">

        <TextView android:id="@+id/tvHeroEmoji"
            android:layout_width="100dp" android:layout_height="100dp"
            android:background="@drawable/circle_gold"
            android:gravity="center" android:text="⚔️" android:textSize="44sp"/>

        <TextView android:id="@+id/tvCarouselCategory"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Warrior" android:textColor="#1B3A6B"
            android:textSize="11sp" android:textStyle="bold"
            android:background="@drawable/badge_top_rated"
            android:paddingStart="10dp" android:paddingEnd="10dp"
            android:paddingTop="4dp" android:paddingBottom="4dp"
            android:layout_marginTop="14dp"/>

        <TextView android:id="@+id/tvCarouselHeroName"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Hero Name" android:textColor="#FFFFFF"
            android:textSize="22sp" android:textStyle="bold"
            android:gravity="center" android:layout_marginTop="10dp"/>

        <TextView android:id="@+id/tvCarouselTagline"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Tagline" android:textColor="#AAAACC"
            android:textSize="13sp" android:gravity="center"
            android:layout_marginTop="6dp" android:lineSpacingMultiplier="1.3"/>

        <LinearLayout android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center"
            android:layout_marginTop="14dp">

            <TextView android:id="@+id/tvCarouselDistrict"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📍 District" android:textColor="#E8A020"
                android:textSize="12sp" android:layout_marginEnd="12dp"/>

            <TextView android:id="@+id/tvCarouselEra"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⏳ Era" android:textColor="#AAAACC" android:textSize="12sp"/>
        </LinearLayout>

        <Button android:id="@+id/btnCarouselRead"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:text="Read Story →" android:textSize="14sp"
            android:textStyle="bold" android:textColor="#1B3A6B"
            android:backgroundTint="#E8A020" android:layout_marginTop="20dp"
            app:cornerRadius="14dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>