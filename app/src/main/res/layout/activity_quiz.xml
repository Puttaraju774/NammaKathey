<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF8E7">

    <!-- Top Bar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="#1B3A6B"
        android:gravity="center_vertical"
        android:paddingStart="8dp" android:paddingEnd="16dp"
        android:orientation="horizontal">

        <ImageButton android:id="@+id/btnBack"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#FFFFFF"/>

        <TextView android:id="@+id/tvHeroName"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hero Quiz"
            android:textColor="#E8A020"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingStart="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ Quest"
            android:textColor="#AAAACC"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- Progress -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingTop="20dp" android:paddingBottom="8dp">

        <TextView android:id="@+id/tvProgress"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="1 / 3"
            android:textColor="#1B3A6B"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginEnd="12dp"/>

        <ProgressBar android:id="@+id/progressBar"
            android:layout_width="0dp" android:layout_height="10dp"
            android:layout_weight="1"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:progressTint="#E8A020"
            android:progressBackgroundTint="#DDDDDD"
            android:max="100"
            android:progress="33"/>
    </LinearLayout>

    <!-- Question Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardQuestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#1B3A6B">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤔"
                android:textSize="40sp"
                android:layout_marginBottom="12dp"/>

            <TextView android:id="@+id/tvQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Question goes here?"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.4"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Answer Options — WHITE background with DARK text -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button android:id="@+id/btnOpt1"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Option A"
                android:textSize="15sp"
                android:textColor="#1B3A6B"
                android:textStyle="bold"
                android:backgroundTint="#FFFFFF"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical|start"
                android:paddingStart="20dp"
                app:cornerRadius="14dp"
                style="@style/Widget.MaterialComponents.Button"/>

            <Button android:id="@+id/btnOpt2"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Option B"
                android:textSize="15sp"
                android:textColor="#1B3A6B"
                android:textStyle="bold"
                android:backgroundTint="#FFFFFF"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical|start"
                android:paddingStart="20dp"
                app:cornerRadius="14dp"
                style="@style/Widget.MaterialComponents.Button"/>

            <Button android:id="@+id/btnOpt3"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Option C"
                android:textSize="15sp"
                android:textColor="#1B3A6B"
                android:textStyle="bold"
                android:backgroundTint="#FFFFFF"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical|start"
                android:paddingStart="20dp"
                app:cornerRadius="14dp"
                style="@style/Widget.MaterialComponents.Button"/>

            <Button android:id="@+id/btnOpt4"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Option D"
                android:textSize="15sp"
                android:textColor="#1B3A6B"
                android:textStyle="bold"
                android:backgroundTint="#FFFFFF"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical|start"
                android:paddingStart="20dp"
                app:cornerRadius="14dp"
                style="@style/Widget.MaterialComponents.Button"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>