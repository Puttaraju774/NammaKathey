<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="140dp"
    android:layout_margin="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Top accent bar -->
        <View android:id="@+id/accentBar"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="@color/saffron"
            android:layout_marginBottom="10dp"/>

        <!-- Hero icon placeholder -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView android:layout_width="44dp" android:layout_height="44dp"
                android:background="@drawable/circle_saffron"
                android:gravity="center" android:text="🏛️" android:textSize="18sp"
                android:layout_marginEnd="10dp"/>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">

                <TextView android:id="@+id/tvDistrictName"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="District"
                    android:textColor="@color/royal_blue"
                    android:textSize="15sp" android:textStyle="bold"
                    android:maxLines="1" android:ellipsize="end"/>

                <TextView android:id="@+id/tvDistrictTheme"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Theme"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"
                    android:maxLines="1" android:ellipsize="end"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Hero count + explore -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView android:id="@+id/tvHeroCount"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1 Hero"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Explore now →"
                android:textColor="@color/saffron"
                android:textSize="11sp" android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>