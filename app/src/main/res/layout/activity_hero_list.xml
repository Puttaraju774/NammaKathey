<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FF">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/circle_white_outline"
            app:tint="#1A1A2E"
            android:padding="8dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/tvSectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hero Gallery"
                android:textColor="#1A1A2E"
                android:textSize="18sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnLanguage"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="ಕನ್ನಡ"
            android:textSize="11sp"
            android:textColor="#1B3A6B"
            android:backgroundTint="#E8A020"
            app:cornerRadius="10dp"/>

    </LinearLayout>

    <!-- SEARCH BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <EditText
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:hint="🔍  Search for a hero..."
            android:textSize="13sp"
            android:textColorHint="#AAAAAA"
            android:textColor="#1A1A2E"
            android:background="@drawable/bg_search_light"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="text"
            android:imeOptions="actionSearch"/>

    </LinearLayout>

    <!-- PICK YOUR QUEST LABEL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☆"
            android:textColor="#E8A020"
            android:textSize="16sp"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pick Your Quest"
            android:textColor="#1A1A2E"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvHeroCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 Hero"
            android:textColor="#888888"
            android:textSize="12sp"/>

    </LinearLayout>

    <!-- FILTER CHIPS -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="All"
                android:textSize="12sp"
                android:backgroundTint="#1A73C8"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="8dp"
                app:cornerRadius="20dp"/>

            <Button
                android:id="@+id/chipWarriors"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Warriors"
                android:textSize="12sp"
                android:backgroundTint="#E8F0FE"
                android:textColor="#1A73C8"
                android:layout_marginEnd="8dp"
                app:cornerRadius="20dp"/>

            <Button
                android:id="@+id/chipQueens"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Queens"
                android:textSize="12sp"
                android:backgroundTint="#E8F0FE"
                android:textColor="#1A73C8"
                android:layout_marginEnd="8dp"
                app:cornerRadius="20dp"/>

            <Button
                android:id="@+id/chipKings"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Kings"
                android:textSize="12sp"
                android:backgroundTint="#E8F0FE"
                android:textColor="#1A73C8"
                app:cornerRadius="20dp"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- HERO LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerHeroes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"/>

    <!-- END OF GALLERY -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="— END OF GALLERY —"
        android:textColor="#CCCCCC"
        android:textSize="11sp"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"/>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🏠" android:textSize="18sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Home" android:textColor="#999999" android:textSize="9sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🗺️" android:textSize="18sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Explore" android:textColor="#1A73C8"
                android:textSize="9sp" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚡" android:textSize="18sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Quests" android:textColor="#999999" android:textSize="9sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🏅" android:textSize="18sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Rewards" android:textColor="#999999" android:textSize="9sp"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>