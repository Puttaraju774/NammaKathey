<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- TOP BAR — Hero name + back + sound -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="12dp"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/circle_white_outline"
            app:tint="#1A1A2E"
            android:padding="10dp"/>

        <!-- Hero name + subtitle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/tvHeroName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hero Name"
                android:textColor="#1A1A2E"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvDistrict"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="District"
                    android:textColor="#888888"
                    android:textSize="12sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textColor="#888888"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/tvHeroEra"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Era"
                    android:textColor="#888888"
                    android:textSize="12sp"/>

            </LinearLayout>
        </LinearLayout>

        <!-- Category label -->
        <TextView
            android:id="@+id/tvCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Saint"
            android:textColor="#E8A020"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"/>

        <!-- Language toggle -->
        <Button
            android:id="@+id/btnLanguage"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="ಕನ್ನಡ"
            android:textSize="11sp"
            android:textColor="#1B3A6B"
            android:backgroundTint="#E8A020"
            app:cornerRadius="10dp"/>

    </LinearLayout>

    <!-- ViewPager2 — full screen illustration + text -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- BOTTOM BAR — TTS + page nav + quiz -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <!-- Page nav row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_chevron_left"
                android:background="@drawable/circle_white_outline"
                app:tint="#1A1A2E"
                android:padding="8dp"
                android:visibility="invisible"/>

            <!-- Dots -->
            <LinearLayout
                android:id="@+id/dotsContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvPageNum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 / 4"
                android:textColor="#888888"
                android:textSize="13sp"
                android:layout_marginEnd="8dp"/>

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_chevron_right"
                android:background="@drawable/circle_blue_outline"
                app:tint="#FFFFFF"
                android:padding="8dp"/>

        </LinearLayout>

        <!-- TTS + Take Quiz row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <!-- TTS button -->
            <ImageButton
                android:id="@+id/btnTts"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_volume_off"
                android:background="@drawable/circle_saffron"
                app:tint="#1A1A2E"
                android:padding="12dp"/>

            <!-- Wave indicator -->
            <TextView
                android:id="@+id/wavesView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="  🔊 Reading aloud..."
                android:textColor="#E8A020"
                android:textSize="12sp"
                android:visibility="gone"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:id="@+id/spacer"/>

            <!-- Take Quiz button -->
            <Button
                android:id="@+id/btnTakeQuiz"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Take Quiz →"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:backgroundTint="#F5C842"
                android:visibility="gone"
                app:cornerRadius="22dp"/>

        </LinearLayout>

    </LinearLayout>



</LinearLayout>