<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ivory">

    <!-- Top Bar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="@color/royal_blue"
        android:gravity="center_vertical" android:paddingStart="8dp" android:paddingEnd="16dp"
        android:orientation="horizontal">

        <ImageButton android:id="@+id/btnBack"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/ivory"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:paddingStart="8dp">
            <TextView android:id="@+id/tvTitle"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Pick Your Journey!"
                android:textColor="@color/saffron" android:textSize="18sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Choose a district to explore"
                android:textColor="#AAAACC" android:textSize="12sp"/>
        </LinearLayout>

        <Button android:id="@+id/btnLanguage"
            android:layout_width="wrap_content" android:layout_height="34dp"
            android:text="ಕನ್ನಡ" android:textSize="11sp"
            android:backgroundTint="@color/saffron" android:textColor="@color/royal_blue"
            app:cornerRadius="8dp"/>
    </LinearLayout>

    <!-- Search Bar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
        android:background="@color/royal_blue"
        android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingBottom="8dp">

        <EditText android:id="@+id/etSearch"
            android:layout_width="match_parent" android:layout_height="36dp"
            android:background="@drawable/bg_search"
            android:hint="Search district..."
            android:textColorHint="#AAAACC"
            android:textColor="@color/ivory"
            android:textSize="14sp"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:inputType="text"
            android:imeOptions="actionSearch"/>
    </LinearLayout>

    <!-- District Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerDistricts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

</LinearLayout>